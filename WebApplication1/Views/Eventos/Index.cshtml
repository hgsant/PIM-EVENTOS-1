@model IEnumerable<EventosPRO.Web.Models.Evento>

@using Microsoft.AspNetCore.Identity

@{
    ViewData["Title"] = "Eventos";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="fw-bold">🎉 Lista de Eventos</h2>

        @if (User.Identity!.IsAuthenticated)
        {
            <a asp-action="Criar" class="btn btn-primary">
                + Novo Evento
            </a>
        }

    </div>

    <form method="get" class="mb-4">

        <div class="input-group">

            <input type="text"
                   name="busca"
                   class="form-control"
                   placeholder="Buscar evento..." />

            <button type="submit" class="btn btn-dark">
                Buscar
            </button>

        </div>

    </form>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success">
            @TempData["Sucesso"]
        </div>
    }

    <div class="row">

        @foreach (var evento in Model)
        {
            <div class="col-md-4 mb-4">

                <div class="card shadow h-100">

                    <div class="card-body">

                        <h4 class="card-title fw-bold">
                            @evento.Nome
                        </h4>

                        <p>
                            <strong>📍 Local:</strong>
                            @evento.Local
                        </p>

                        <p>
                            <strong>📅 Data:</strong>
                            @evento.Data.ToString("dd/MM/yyyy")
                        </p>

                        <p>
                            @evento.Descricao
                        </p>

                        @if (!string.IsNullOrEmpty(evento.AnaliseIA))
                        {
                            <div class="alert alert-info">
                                <strong>🤖 IA:</strong>
                                @evento.AnaliseIA
                            </div>
                        }

                    </div>

                    <div class="card-footer bg-white border-0">

                        @if (User.Identity!.IsAuthenticated)
                        {
                            <a asp-action="Editar"
                               asp-route-id="@evento.Id"
                               class="btn btn-warning">
                                Editar
                            </a>

                            <a asp-action="Excluir"
                               asp-route-id="@evento.Id"
                               class="btn btn-danger">
                                Excluir
                            </a>
                        }

                    </div>

                </div>

            </div>
        }

    </div>

</div>