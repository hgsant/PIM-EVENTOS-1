@model EventosPRO.Web.Models.Evento

<h1 class="mb-4">Novo Evento</h1>

<form asp-action="Criar" method="post">

    <div class="mb-3">
        <label class="form-label">Nome do Evento</label>
        <input asp-for="Nome" class="form-control bg-dark text-white border-secondary" />
    </div>

    <div class="mb-3">
        <label class="form-label">Local</label>
        <input asp-for="Local" class="form-control bg-dark text-white border-secondary" />
    </div>

    <div class="mb-3">
        <label class="form-label">Data</label>
        <input asp-for="Data" type="date" class="form-control bg-dark text-white border-secondary" />
    </div>

    <div class="mb-3">
        <label class="form-label">Descrição</label>
        <textarea asp-for="Descricao" class="form-control bg-dark text-white border-secondary"></textarea>
    </div>

    <button type="submit" class="btn btn-primary">
        Salvar Evento
    </button>

</form>